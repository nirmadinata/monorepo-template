        "skills-update": "skills update",
        "typecheck": "turbo run typecheck"
    },
    "dependencies": {
        "@cloudflare/vite-plugin": "^1.43.0"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "oxfmt": "^0.57.0",
        "oxlint": "^1.72.0",
        "oxlint-tailwindcss": "^1.3.4",
        "skills": "^1.5.14",
        "turbo": "^2.10.4",
        "ultracite": "7.8.4"
    },
    "peerDependencies": {
        "typescript": "^6.0.3"
    },
    "packageManager": "bun@1.3.13"
