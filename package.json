{
    "name": "template",
    "private": true,
    "workspaces": [
        "packages/*",
        "apps/*",
        "templates/*"
    ],
    "type": "module",
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "check": "bun --bun ultracite check",
